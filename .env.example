# Local : copiez vers src/.env
# Vercel : Project Settings → Environment Variables (Production)
# Clé : https://openrouter.ai/keys — ne committez jamais ce fichier

# Obligatoire : votre clé OpenRouter (sk-or-v1-…)
OPENROUTER_API_KEY=

# Si ce modèle échoue (404/429), le serveur essaie automatiquement les replis (server/index.ts)
OPENROUTER_MODEL=liquid/lfm-2.5-1.2b-instruct:free

# Optionnel :
SITE_URL=http://localhost:5173
PORT=8080
